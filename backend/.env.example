# Database
DATABASE_URL=postgresql+psycopg2://postgres:yourpassword@localhost:5432/modzero

# Application
ENVIRONMENT=development
DEBUG=true

# JWT
SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Initial superuser (created on first startup)
INITIAL_SUPERUSER_USERNAME=admin
INITIAL_SUPERUSER_EMAIL=admin@modzero.com
INITIAL_SUPERUSER_PASSWORD=admin123

# CORS (comma-separated origins, or * for development)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Azure / Microsoft Graph (optional)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
