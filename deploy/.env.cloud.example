# ═══════════════════════════════════════════════════════════════════
# ModZero — Cloud / Production Environment Template
# ═══════════════════════════════════════════════════════════════════
#
# Copy this file to .env at the repo root, then fill in every value
# marked REQUIRED. Values marked OPTIONAL can be left empty if that
# feature is not used.
#
# NEVER commit .env to version control.
# NEVER reuse the placeholder strings below as real secrets.
#
# Quick-generate secrets:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
# REQUIRED — change username and password from these placeholders.
POSTGRES_USER=modzero
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_RANDOM_PASSWORD
POSTGRES_DB=modzero
# REQUIRED — must match POSTGRES_USER/PASSWORD/DB above.
# For managed PostgreSQL (RDS, Cloud SQL) replace the host and port.
DATABASE_URL=postgresql+psycopg2://modzero:REPLACE_WITH_STRONG_RANDOM_PASSWORD@db:5432/modzero

# ── Backend Security ──────────────────────────────────────────────
# REQUIRED — 64-char random hex. All JWT tokens are signed with this.
# Changing this value immediately invalidates all active sessions.
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX
ACCESS_TOKEN_EXPIRE_MINUTES=480
ENVIRONMENT=production
DEBUG=false
JWT_ALGORITHM=HS256

# ── Initial Superuser (created once on first startup) ─────────────
# REQUIRED — change admin123 before first startup on a real server.
INITIAL_SUPERUSER_USERNAME=admin
INITIAL_SUPERUSER_EMAIL=admin@your-domain.com
INITIAL_SUPERUSER_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# ── CORS ──────────────────────────────────────────────────────────
# REQUIRED for cloud — set to the exact origin your frontend is
# served from. Do NOT use * in production.
# Comma-separate multiple origins if needed.
CORS_ORIGINS=https://your-domain.com

# ── Public URL and Cookies ────────────────────────────────────────
# REQUIRED — full HTTPS URL of the deployment. Used to construct
# access URLs returned to clients.
PUBLIC_BASE_URL=https://your-domain.com
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# ── Backend ↔ Connector hop ──────────────────────────────────────
# REQUIRED — shared HMAC secret between backend and connector.
# Must match on every connector host.
CONNECTOR_HOP_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
CONNECTOR_BASE_URL=http://connector:8443
CONNECTOR_TRANSPORT=direct_http

# ── Frontend build ────────────────────────────────────────────────
# REQUIRED — baked into the React build at docker build time.
# Must be the public-facing API URL (with /api suffix).
# Use /api for same-domain deployment behind reverse proxy.
VITE_API_BASE=https://your-domain.com/api
VITE_SOCKET_URL=https://your-domain.com

# ── Connector enrollment ──────────────────────────────────────────
# Generated in the admin UI after first login.
# Leave empty on first deploy; set after enrollment.
MODZERO_ENROLL_TOKEN=

# ── Headscale / WireGuard tunnel (OPTIONAL) ───────────────────────
# Set HEADSCALE_ENABLED=false if you have not deployed Headscale.
# When true, HEADSCALE_URL and HEADSCALE_API_KEY must also be set.
HEADSCALE_ENABLED=false
HEADSCALE_URL=
# WARNING: HEADSCALE_API_KEY is sensitive. It is NEVER returned in
# any API response, logged, or stored in the database.
HEADSCALE_API_KEY=
HEADSCALE_USER=modzero
HEADSCALE_POLL_INTERVAL=30
HEADSCALE_BOOTSTRAP_TRY_API=false

# ── Azure / Microsoft Graph (OPTIONAL) ───────────────────────────
# Required only for Intune device posture and Entra ID user data.
# Leave all empty if not using Graph integration.
# Register an app in Azure Portal → App registrations.
# Grant Application permissions: User.Read.All,
# DeviceManagementManagedDevices.Read.All, AuditLog.Read.All
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_GRAPH_SCOPES=https://graph.microsoft.com/.default

# ── Demo connector proxy (local testing only) ─────────────────────
# Used by verify_all.py to construct proxy test URLs.
# In production this must point to the real connector host/port.
# Do NOT expose the connector proxy on a public port.
DEMO_CONNECTOR_PROXY_BASE_URL=http://localhost:18080
