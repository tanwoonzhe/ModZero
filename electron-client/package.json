{
  "name": "modzero-dashboard",
  "version": "1.0.0",
  "description": "ModZero Dashboard — Electron wrapper for the React admin UI",
  "main": "dist/main.js",
  "author": "ModZero Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n electron,tsc \"wait-on http://localhost:5173 && electron .\" \"tsc -p tsconfig.main.json --watch\"",
    "dev:frontend": "cd ../frontend && npm run dev",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "cd ../frontend && npm run build && cd ../electron-client && npm run build:main",
    "electron": "electron .",
    "start": "npm run build && electron .",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.modzero.dashboard",
    "productName": "ModZero Dashboard",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  }
}
