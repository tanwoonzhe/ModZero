# ═══════════════════════════════════════════════════════════════════
# ModZero — Environment Variables
# Copy to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=modzero
DATABASE_URL=postgresql+psycopg2://postgres:your-db-password@db:5432/modzero

# ── Backend ───────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
ENVIRONMENT=development
DEBUG=true
JWT_ALGORITHM=HS256

# ── Initial Superuser (created on first startup) ─────────────────
INITIAL_SUPERUSER_USERNAME=admin
INITIAL_SUPERUSER_EMAIL=admin@modzero.com
INITIAL_SUPERUSER_PASSWORD=admin123

# ── CORS (comma-separated origins, or * for development) ─────────
CORS_ORIGINS=*

# ── Azure / Microsoft Graph (optional — needed for tenant assessment)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Frontend ──────────────────────────────────────────────────────
VITE_API_BASE=http://localhost:8000/api
VITE_SOCKET_URL=http://localhost:8000

# ── Connector (set after generating enrollment token in dashboard)
MODZERO_ENROLL_TOKEN=