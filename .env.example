# ═══════════════════════════════════════════════════════════════════
# ModZero — Environment Variables
# Copy to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_DB=modzero
DATABASE_URL=postgresql+psycopg2://postgres:your-db-password@db:5432/modzero

# ── Backend ───────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
ENVIRONMENT=development
DEBUG=true
JWT_ALGORITHM=HS256

# ── Initial Superuser (created on first startup) ─────────────────
INITIAL_SUPERUSER_USERNAME=admin
INITIAL_SUPERUSER_EMAIL=admin@modzero.com
INITIAL_SUPERUSER_PASSWORD=admin123

# ── CORS (comma-separated origins, or * for development) ─────────
CORS_ORIGINS=*

# ── Cloud / public URL (set in production behind TLS / reverse proxy) ──
# When set, /api/resource-access/gate uses this for bootstrap_url instead
# of request.base_url. Required for ECS / Alibaba Cloud deployment.
PUBLIC_BASE_URL=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── Backend ↔ Connector hop ──────────────────────────────────────
# Internal docker URL of the connector. The /r/<slug> route forwards
# protected requests to this endpoint with a signed HMAC header.
CONNECTOR_BASE_URL=http://connector:8443
CONNECTOR_HOP_SECRET=change-this-to-a-long-random-string-too

# ── Azure / Microsoft Graph (optional — needed for tenant assessment)
# Legacy vars used by azure_service.py / graph_client.py
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Microsoft Graph — direct integration (graph_service.py) ─────────────────
# Register an app in Azure AD → App registrations → New registration.
# Grant it Application permissions (not Delegated): User.Read.All,
# Group.Read.All, DeviceManagementManagedDevices.Read.All.
# Then create a client secret and fill in the values below.
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_GRAPH_SCOPES=https://graph.microsoft.com/.default

# ── Frontend ──────────────────────────────────────────────────────
VITE_API_BASE=http://localhost:8000/api
VITE_SOCKET_URL=http://localhost:8000

# ── Connector (set after generating enrollment token in dashboard)
MODZERO_ENROLL_TOKEN=